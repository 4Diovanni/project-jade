# ─────────────────────────────────────────────────────────────
# Project Jade — variáveis de ambiente (copie para .env)
#   cp .env.example .env    (ou copy no Windows)
# NUNCA commite o arquivo .env — ele está no .gitignore.
# ─────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────
# Provider ativo: ollama | openai | anthropic | gemini
JADE_LLM_PROVIDER=ollama

# Opção 1 — 100% local e privado (Ollama)
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text   # embeddings do RAG (ollama pull nomic-embed-text)

# Opção 2 — nuvem (preencha só o que for usar)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Roteador dual-model (llama3 local + Claude na nuvem) ─────
# Com ANTHROPIC_API_KEY preenchida, perguntas informativas/complexas vão para
# o Claude; conversa comum e dados pessoais ficam no llama3 (privacidade).
# A chave vem do console.anthropic.com (≠ assinatura Claude Pro).
JADE_ROUTER_ENABLED=true
JADE_CLOUD_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-opus-4-8
# Modelo mais barato para o escalonamento (opcional):
# ANTHROPIC_MODEL=claude-haiku-4-5

# ── Obsidian (RAG) ───────────────────────────────────────────
# "." = a raiz deste repositório É o vault. Aponte para outro
# caminho se seu vault estiver em outro lugar.
OBSIDIAN_VAULT_PATH=.

# ── Personalidade & memória viva ─────────────────────────────
# Dono da Jade — o comportamento dela é voltado a esta pessoa.
JADE_USER_NAME=Giovanni
# Aprender fatos sobre o usuário (via LLM) ao encerrar/limpar a conversa.
JADE_PROFILE_UPDATE=true

# ── Bancos de dados ──────────────────────────────────────────
CHROMA_DB_PATH=./database/chroma_db
CHROMA_COLLECTION=obsidian_notes
SQLITE_PATH=./database/jade.db

# ── RAG (opcional — têm padrão no código) ────────────────────
# RAG_CHUNK_SIZE=800
# RAG_CHUNK_OVERLAP=120
# RAG_TOP_K=4

# ── Voz (Fase 3) ─────────────────────────────────────────────
# STT local (faster-whisper): tiny|base|small|medium|large-v3
JADE_WHISPER_MODEL=base
JADE_WHISPER_LANGUAGE=pt
# TTS: edge (online, alta qualidade) | pyttsx3 (offline)
JADE_TTS_BACKEND=edge
JADE_TTS_VOICE=pt-BR-FranciscaNeural
# Onde os áudios gerados pelo Jade são salvos (padrão: <vault>/Áudios)
# JADE_AUDIO_DIR=./obsidian_notes/Áudios

# ── API (FastAPI) ────────────────────────────────────────────
JADE_API_HOST=127.0.0.1
JADE_API_PORT=8000
