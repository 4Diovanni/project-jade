# ─────────────────────────────────────────────────────────────
# Project Jade — .gitignore
# Este repositório vive DENTRO do vault do Obsidian. As regras
# abaixo garantem que apenas o código do projeto seja versionado.
# ─────────────────────────────────────────────────────────────

# Segredos e configuração local
.env
.env.local
*.key

# Estado do editor Obsidian (layout/plugins pessoais)
.obsidian/

# Notas pessoais do vault na raiz — mantêm-se PRIVADAS.
# Só os documentos do projeto (whitelist abaixo) são versionados.
/*.md
!/README.md
!/projeto_jade_arquitetura.md
!/CLAUDE.md
!/COMO_USAR.md

# Vault de memória do Jade (conversas .md + notas pessoais) — PRIVADO.
/obsidian_notes/

# Áudios gerados pelo TTS (nunca versionados).
*.mp3
*.wav

# Bancos de dados locais (gerados em runtime)
database/chroma_db/
database/*.db
database/*.sqlite3

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node (whatsapp_bot)
node_modules/
npm-debug.log*

# SO / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
